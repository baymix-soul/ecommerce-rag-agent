# 演示环境变量模板
# 复制此文件为 deploy/.env 并填入真实值
# 绝对不要将 .env 提交到 Git 仓库
#
# Spring Boot 通过 application.yml 中 ${VAR_NAME:default} 引用这些变量

# ===== 服务端口 =====
SERVER_PORT=8080

# ===== Vector Store（向量数据库）=====
VECTOR_STORE=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=ecommerce_rag_chunks_demo
# Mock Embedding 维度为 64；真实 Ark Embedding 维度通常为 1024 或 2048
QDRANT_VECTOR_SIZE=64
QDRANT_DISTANCE=Cosine
QDRANT_RECREATE_ON_START=false

# ===== Redis =====
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
# 本地演示可留空
REDIS_PASSWORD=
REDIS_DATABASE=0

# ===== Auth（Demo 登录）=====
DEMO_USERNAME=demo
DEMO_PASSWORD=demo123
AUTH_TOKEN_TTL_SECONDS=604800

# ===== Chat / LLM 配置 =====
# 没有真实 API Key 时设为 true，使用 Mock LLM（推荐质量下降）
MOCK_LLM_ENABLED=false

# LLM 提供商：doubao / openai-style
LLM_PROVIDER=doubao
# 必须填写真实 API Key（如果 MOCK_LLM_ENABLED=false）
LLM_API_KEY=your_api_key_here
LLM_MODEL=doubao-seed-2-0-lite-260428
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_TIMEOUT_SECONDS=30

# ===== Embedding 配置 =====
# provider 可选值: mock / openai-style / ark-multimodal
EMBEDDING_PROVIDER=ark-multimodal
EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 如果使用真实 Embedding，需要填写 API Key
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_MODEL=doubao-embedding-vision-251215
# EMBEDDING_DIMENSION 必须等于 QDRANT_VECTOR_SIZE
EMBEDDING_DIMENSION=64
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_BATCH_SIZE=16
ARK_MULTIMODAL_EMBEDDING_PATH=/embeddings/multimodal

# ===== Query Rewrite（软语义扩展）=====
QUERY_REWRITE_ENABLED=true
QUERY_REWRITE_PROVIDER=lexicon

# ===== Query Planner（LLM 结构化理解）=====
# demo 稳定性优先时可设为 false 关闭 planner
QUERY_PLANNER_ENABLED=true
QUERY_PLANNER_MODE=shadow
QUERY_PLANNER_TIMEOUT_SECONDS=10
QUERY_PLANNER_MIN_CONFIDENCE=0.85

# ===== TTS 语音合成 =====
# TTS 需要容器内安装 edge-tts（Dockerfile 已配置）
TTS_ENABLED=true
TTS_PROVIDER=edge-tts-cli
TTS_AUDIO_DIR=./data/tts
# Android Emulator 访问宿主机时建议设置为 http://10.0.2.2:8080
# 真机测试时改为宿主机局域网 IP
TTS_PUBLIC_BASE_URL=http://10.0.2.2:8080
TTS_MAX_TEXT_LENGTH=500
TTS_DEFAULT_VOICE=zh-CN-XiaoxiaoNeural
TTS_DEFAULT_FORMAT=mp3
TTS_COMMAND_TIMEOUT_SECONDS=30

# ===== 性能追踪 =====
PERF_TRACE_ENABLED=true
PERF_TRACE_LOG_ENABLED=true
PERF_TRACE_RECENT_ENABLED=true
PERF_TRACE_RECENT_SIZE=100
PERF_SLOW_THRESHOLD_MS=3000
PERF_LOG_QUERY_PREVIEW=true
PERF_QUERY_PREVIEW_LENGTH=40
