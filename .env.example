# 环境变量模板
# 复制此文件为 .env 并填入真实值，不要将 .env 提交到 Git 仓库
#
# Spring Boot 读取方式: 可通过 application.yml 中 ${VAR_NAME} 引用
# 或通过 @Value("${var.name}") 注解读取

# ===== 应用配置 =====
APP_NAME=ecommerce-rag-agent
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# ===== 服务配置 =====
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ===== LLM 配置 (Doubao-Seed-2.0-lite / OpenAI-compatible API) =====
LLM_API_KEY=your_llm_api_key_here
LLM_API_BASE=https://api.example.com/v1
LLM_MODEL_NAME=doubao-seed-2.0-lite
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_SECONDS=60

# ===== Embedding 配置 =====
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_API_BASE=https://api.example.com/v1
EMBEDDING_MODEL_NAME=your_embedding_model_here
EMBEDDING_DIMENSION=1536

# ===== 向量数据库配置 =====
# 选项: qdrant 或 chroma
VECTOR_DB_TYPE=qdrant
# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_COLLECTION_NAME=ecommerce_products
# Chroma (备选)
# CHROMA_HOST=localhost
# CHROMA_PORT=8001
# CHROMA_COLLECTION_NAME=ecommerce_products

# ===== 商品数据配置 =====
PRODUCT_DATA_PATH=classpath:data/products.json