# 环境变量模板
# 复制此文件为 .env 并填入真实值，不要将 .env 提交到 Git 仓库
#
# Spring Boot 读取方式: application.yml 中 ${VAR_NAME:default} 引用

# ===== 应用配置 =====
APP_NAME=ecommerce-rag-agent
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO

# ===== 服务配置 =====
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ===== LLM 配置 (Doubao-Seed-2.0-lite / OpenAI-compatible API) =====
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=your_llm_model_here
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_SECONDS=30

# ===== Chat 配置 =====
MOCK_LLM_ENABLED=true

# ===== Embedding 配置 =====
EMBEDDING_API_KEY=your_embedding_api_key_here

# ===== 向量数据库配置 =====
VECTOR_ENABLED=false
QDRANT_URL=http://localhost:6333
